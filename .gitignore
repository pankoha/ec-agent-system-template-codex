# ========================================
# 機密ファイル（MUST — 最優先）
# このブロックは絶対に消さない。
# Claude Codeのdeny設定より優先度が高い。
# gitignoreから漏れてpushされた瞬間、ネット上に公開される。
# ========================================
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
credentials*
*secret*
*_token
*.pfx
*.p12
local-llm-gateway/config/sensitive-patterns.local.json

# ========================================
# OS / 一時ファイル
# ========================================
.DS_Store
Thumbs.db
desktop.ini
*.tmp
~$*
*.swp
*~

# ========================================
# エディタ・IDE
# ========================================
.vscode/
.idea/

# ========================================
# Claude Code ユーザーローカル設定
# ========================================
.claude/settings.local.json
.claude/.credentials.json
CLAUDE.local.md

# ========================================
# 大容量ファイル
# ========================================
*.mp4
*.mov
*.zip
*.tar.gz

# ========================================
# セキュリティ監査レポート（実鍵の断片を含む可能性）
# ========================================
security-audit/gitleaks-workdir.json
