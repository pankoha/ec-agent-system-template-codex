# ========================================
# 環境変数テンプレート
# ========================================
# このファイルは .env のサンプルです。
#
# 【重要】使い方
# 1. このファイルを .env という名前でコピー: cp .env.example .env
# 2. 下の各値を実際のAPIキー等に書き換える
# 3. .env は絶対に git commit しない（.gitignoreで除外済）
# ========================================

# ========== Claude Code / Anthropic ==========
# Claude Code を使う場合は別途 Anthropic Console でセットアップ
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=YOUR_API_KEY_HERE

# ========== Google Analytics 4（ec-insight 系で使用） ==========
# GA4_PROPERTY_ID=YOUR_PROPERTY_ID
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# ========== Google Sheets（レポート出力等） ==========
# GOOGLE_SPREADSHEET_ID=YOUR_SPREADSHEET_ID

# ========== Shopify（ec-solo / ec-operations 系で使用） ==========
# SHOPIFY_STORE_URL=your-store.myshopify.com
# SHOPIFY_API_KEY=YOUR_API_KEY
# SHOPIFY_API_SECRET=YOUR_API_SECRET
# SHOPIFY_ADMIN_TOKEN=YOUR_ADMIN_TOKEN

# ========== Meta / Instagram（ec-acquisition / ec-sns-analytics で使用） ==========
# IG_USER_ID=YOUR_IG_USER_ID
# IG_ACCESS_TOKEN=YOUR_LONG_LIVED_TOKEN
# IG_APP_ID=YOUR_APP_ID
# IG_APP_SECRET=YOUR_APP_SECRET
# FB_PAGE_ID=YOUR_PAGE_ID

# ========== X (Twitter)（ec-sns-analytics で使用） ==========
# X_API_KEY=YOUR_API_KEY
# X_API_SECRET=YOUR_API_SECRET
# X_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
# X_ACCESS_TOKEN_SECRET=YOUR_ACCESS_TOKEN_SECRET
# X_BEARER_TOKEN=YOUR_BEARER_TOKEN

# ========== Amazon SP-API（ec-amazon-strategy で使用） ==========
# AMAZON_SELLER_ID=YOUR_SELLER_ID
# AMAZON_MARKETPLACE_ID=YOUR_MARKETPLACE_ID
# AMAZON_SP_API_REFRESH_TOKEN=YOUR_REFRESH_TOKEN
# AMAZON_SP_API_CLIENT_ID=YOUR_CLIENT_ID
# AMAZON_SP_API_CLIENT_SECRET=YOUR_CLIENT_SECRET

# ========== Notion（notion-meeting-tasks で使用） ==========
# NOTION_API_TOKEN=secret_YOUR_TOKEN

# ========== Chatwork / Slack（通知用） ==========
# CHATWORK_API_TOKEN=YOUR_TOKEN
# SLACK_WEBHOOK_URL=YOUR_WEBHOOK_URL

# ========== ログ・実行環境 ==========
NODE_ENV=development
LOG_LEVEL=info
